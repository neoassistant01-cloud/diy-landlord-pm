generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Property {
  id          String   @id @default(cuid())
  address     String
  type        String
  units       Int
  rentAmount  Float
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenants     Tenant[]
  maintenance MaintenanceRequest[]
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  leaseStart  DateTime
  leaseEnd    DateTime
  unitAssigned String
  rentStatus  String
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model MaintenanceRequest {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  description String
  priority    String
  status      String
  createdDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime
  method    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
